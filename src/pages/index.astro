---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProjectSection from '../components/ProjectSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import EducationSection from '../components/EducationSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <Hero />
  <ProjectSection />
  <ExperienceSection />
  <EducationSection />
  <!-- Project Modal Shell -->
  <div class="fixed inset-0 z-[300] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300" id="project-modal">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-md" onclick="closeModal()"></div>
    <div class="relative bg-white rounded-2xl max-w-[720px] w-[90%] max-h-[85vh] overflow-y-auto transform translate-y-8 scale-[0.97] transition-transform duration-500" id="modal-content" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"></div>
  </div>

  <Footer />

  <script src="../scripts/interactions.ts"></script>
  <script src="../scripts/modal.ts"></script>
  <script src="../scripts/lightbox.ts"></script>
  <script src="../scripts/i18n-client.ts"></script>
</BaseLayout>

---
import { t } from '../i18n/utils';
import { projects } from '../data/projects';
---

<section id="projects" class="py-16 px-6">
  <div class="max-w-2xl mx-auto">
    <p class="text-xs text-accent font-medium tracking-[0.2em] uppercase mb-3 reveal" data-i18n="projects.label">{t('projects.label')}</p>
    <h2 class="font-light text-stone-900 text-3xl mb-10 tracking-tight reveal" data-i18n="projects.title">{t('projects.title')}</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      {projects.map(project => {
        const locale = project.locales.en;
        return (
          <div class="reveal cursor-pointer group" data-project={project.slug} onclick={`openModal('${project.slug}')`}>
            {/* Thumbnail */}
            <div class="w-full rounded-xl overflow-hidden bg-stone-100 mb-3">
              <img
                src={`/${project.images[0]}`}
                alt={locale.title}
                loading="lazy"
                class="w-full h-auto block group-hover:scale-[1.03] transition-transform duration-500"
              />
            </div>

            {/* Content */}
            <h3 class="font-medium text-stone-900 text-sm tracking-tight mb-0.5 group-hover:text-accent transition-colors duration-200" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
            <p class="text-xs text-stone-400 font-normal mb-1.5">{locale.subtitle}</p>
            <p class="text-stone-500 text-xs leading-relaxed mb-2" data-i18n={`projects.${project.slug}.desc`}>{locale.description.length > 100 ? locale.description.slice(0, 100) + '...' : locale.description}</p>
            <div class="flex gap-1 flex-wrap">
              {project.tags.slice(0, 3).map(tag => (
                <span class="text-[10px] px-1.5 py-0.5 border border-stone-200 rounded-full text-stone-400">{tag}</span>
              ))}
              {project.tags.length > 3 && (
                <span class="text-[10px] text-stone-300">+{project.tags.length - 3}</span>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

---
import { t } from '../i18n/utils';
import { projects } from '../data/projects';
---

<section id="projects" class="pt-8 pb-16 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-light text-stone-900 dark:text-stone-100 text-2xl mb-8 tracking-tight reveal" data-i18n="projects.title">{t('projects.title')}</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {projects.map((project, i) => {
        const locale = project.locales.en;
        const isHero = i === 0;
        const objPos = project.imageStyle === 'phone' ? 'object-top' : 'object-center';
        const cardClass = `reveal cursor-pointer group rounded-2xl overflow-hidden border border-stone-100 dark:border-stone-800 hover:border-stone-300 dark:hover:border-stone-700 bg-white dark:bg-stone-900/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 transition-all duration-200`;

        return isHero ? (
          /* Hero card — full width, horizontal */
          <div
            class={`${cardClass} sm:col-span-2`}
            style={`--stagger:0ms`}
            data-project={project.slug}
            role="button"
            tabindex="0"
            onclick={`openModal('${project.slug}')`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();openModal('${project.slug}')}`}
          >
            <div class="flex items-stretch">
              {project.images.length > 0 ? (
                <div class="w-36 sm:w-44 flex-shrink-0 overflow-hidden bg-stone-100 dark:bg-stone-800">
                  <img
                    src={`/${project.images[0]}`}
                    alt={locale.title}
                    loading="eager"
                    width="176"
                    height="320"
                    class={`w-full h-full object-cover ${objPos} min-h-[210px] group-hover:scale-[1.03] transition-transform duration-500`}
                  />
                </div>
              ) : (
                <div class="w-36 sm:w-44 flex-shrink-0 min-h-[210px]" style={`background: ${project.gradient}`}></div>
              )}
              <div class="flex-1 min-w-0 p-5 flex flex-col justify-center">
                <h3 class="font-medium text-stone-900 dark:text-stone-100 text-base tracking-tight mb-0.5 group-hover:text-accent transition-colors duration-200" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
                <p class="text-sm text-stone-400 dark:text-stone-500 mb-2.5">{locale.subtitle}</p>
                <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed mb-4 hidden sm:block" data-i18n={`projects.${project.slug}.desc`}>{locale.description.length > 220 ? locale.description.slice(0, 220) + '...' : locale.description}</p>
                <div class="flex gap-1.5 flex-wrap">
                  {project.tags.slice(0, 5).map(tag => (
                    <span class="text-[11px] px-2 py-0.5 border border-stone-200 dark:border-stone-700 rounded-full text-stone-400 dark:text-stone-500">{tag}</span>
                  ))}
                  {project.tags.length > 5 && (
                    <span class="text-[11px] text-stone-300 dark:text-stone-600">+{project.tags.length - 5}</span>
                  )}
                </div>
              </div>
            </div>
          </div>
        ) : (
          /* Grid card — half width, stacked */
          <div
            class={cardClass}
            style={`--stagger:${i * 50}ms`}
            data-project={project.slug}
            role="button"
            tabindex="0"
            onclick={`openModal('${project.slug}')`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();openModal('${project.slug}')}`}
          >
            {project.images.length > 0 ? (
              <div class="w-full h-44 overflow-hidden bg-stone-100 dark:bg-stone-800">
                <img
                  src={`/${project.images[0]}`}
                  alt={locale.title}
                  loading="lazy"
                  width="330"
                  height="176"
                  class={`w-full h-full object-cover ${objPos} group-hover:scale-[1.03] transition-transform duration-500`}
                />
              </div>
            ) : (
              <div class="w-full h-44" style={`background: ${project.gradient}`}></div>
            )}
            <div class="p-4">
              <h3 class="font-medium text-stone-900 dark:text-stone-100 text-sm tracking-tight mb-0.5 group-hover:text-accent transition-colors duration-200" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
              <p class="text-xs text-stone-400 dark:text-stone-500 mb-2.5">{locale.subtitle}</p>
              <div class="flex gap-1.5 flex-wrap">
                {project.tags.slice(0, 3).map(tag => (
                  <span class="text-[10px] px-1.5 py-0.5 border border-stone-200 dark:border-stone-700 rounded-full text-stone-400 dark:text-stone-500">{tag}</span>
                ))}
                {project.tags.length > 3 && (
                  <span class="text-[10px] text-stone-300 dark:text-stone-600">+{project.tags.length - 3}</span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

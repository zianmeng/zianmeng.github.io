---
import { t } from '../i18n/utils';
import { projects } from '../data/projects';
---

<section id="projects" class="py-16 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-light text-stone-900 dark:text-stone-100 text-2xl mb-10 tracking-tight reveal" data-i18n="projects.title">{t('projects.title')}</h2>

    <div class="space-y-10">
      {projects.map(project => {
        const locale = project.locales.en;
        return (
          <div class="reveal cursor-pointer group flex gap-5 items-start rounded-xl px-3 py-2 -mx-3 hover:bg-stone-50 dark:hover:bg-stone-900/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-stone-950 transition-colors duration-200" style={`--stagger:${projects.indexOf(project) * 50}ms`} data-project={project.slug} role="button" tabindex="0" onclick={`openModal('${project.slug}')`} onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();openModal('${project.slug}')}`}>
            {/* Thumbnail */}
            {project.images.length > 0 ? (
              <div class="flex-shrink-0 w-40 rounded-xl overflow-hidden bg-stone-100 dark:bg-stone-800">
                <img
                  src={`/${project.images[0]}`}
                  alt={locale.title}
                  loading="lazy"
                  class="w-full h-auto block group-hover:scale-[1.03] transition-transform duration-500"
                />
              </div>
            ) : (
              <div class="flex-shrink-0 w-40 h-28 rounded-xl flex items-center justify-center text-3xl" style={`background: ${project.gradient}`}>
                {project.emoji}
              </div>
            )}

            {/* Content */}
            <div class="flex-1 min-w-0 pt-1">
              <h3 class="font-medium text-stone-900 dark:text-stone-100 text-base tracking-tight mb-0.5 group-hover:text-accent transition-colors duration-200" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
              <p class="text-sm text-stone-400 dark:text-stone-500 font-normal mb-2">{locale.subtitle}</p>
              <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed mb-3" data-i18n={`projects.${project.slug}.desc`}>{locale.description.length > 180 ? locale.description.slice(0, 180) + '...' : locale.description}</p>
              <div class="flex gap-1.5 flex-wrap">
                {project.tags.slice(0, 5).map(tag => (
                  <span class="text-[11px] px-2 py-0.5 border border-stone-200 dark:border-stone-700 rounded-full text-stone-400 dark:text-stone-500">{tag}</span>
                ))}
                {project.tags.length > 5 && (
                  <span class="text-[11px] text-stone-300 dark:text-stone-600">+{project.tags.length - 5}</span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

---
import { t } from '../i18n/utils';
import { projects } from '../data/projects';
---

<section id="projects" class="pt-8 pb-16 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-light text-stone-900 dark:text-stone-100 text-2xl mb-8 tracking-tight reveal" data-i18n="projects.title">{t('projects.title')}</h2>

    <div class="flex flex-col">
      {projects.map((project, i) => {
        const locale = project.locales.en;
        const objPos = project.imageStyle === 'phone' ? 'object-top' : 'object-center';

        return (
          <div
            class="reveal group flex items-center gap-4 py-3.5 border-b border-stone-100 dark:border-stone-800 last:border-0 cursor-pointer hover:bg-stone-50 dark:hover:bg-stone-900/40 -mx-3 px-3 rounded-lg transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40"
            style={`--stagger:${i * 40}ms`}
            data-project={project.slug}
            role="button"
            tabindex="0"
            onclick={`openModal('${project.slug}')`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();openModal('${project.slug}')}`}
          >
            {/* Thumbnail */}
            <div class="flex-shrink-0 w-14 h-14 rounded-xl overflow-hidden bg-stone-100 dark:bg-stone-800">
              {project.images.length > 0 ? (
                <img
                  src={`/${project.images[0]}`}
                  alt={locale.title}
                  loading={i < 2 ? 'eager' : 'lazy'}
                  width="56"
                  height="56"
                  class={`w-full h-full object-cover ${objPos}`}
                />
              ) : (
                <div class="w-full h-full" style={`background: ${project.gradient}`}></div>
              )}
            </div>

            {/* Content */}
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline justify-between gap-2">
                <h3 class="font-medium text-stone-900 dark:text-stone-100 text-sm tracking-tight group-hover:text-accent transition-colors duration-150 truncate" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
                <span class="flex-shrink-0 text-[10px] text-stone-300 dark:text-stone-600">{project.tags.find(t => t.includes('App') || t.includes('macOS') || t.includes('iOS')) ?? project.tags[project.tags.length - 1]}</span>
              </div>
              <p class="text-xs text-stone-400 dark:text-stone-500 mt-0.5 truncate">{locale.subtitle}</p>
            </div>

            {/* Arrow */}
            <div class="flex-shrink-0 text-stone-200 dark:text-stone-700 group-hover:text-stone-400 dark:group-hover:text-stone-500 transition-colors duration-150">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

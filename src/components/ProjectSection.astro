---
import { t } from '../i18n/utils';
import { projects } from '../data/projects';
---

<section id="projects" class="pt-8 pb-16 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-light text-stone-900 dark:text-stone-100 text-2xl mb-6 tracking-tight reveal" data-i18n="projects.title">{t('projects.title')}</h2>

    <div class="flex flex-col gap-3">
      {projects.map((project, i) => {
        const locale = project.locales.en;
        const objPos = project.imageStyle === 'phone' ? 'object-top' : 'object-center';
        const desc = locale.description.length > 160 ? locale.description.slice(0, 160) + '…' : locale.description;

        return (
          <div
            class="reveal group flex items-stretch gap-0 rounded-2xl overflow-hidden border border-stone-100 dark:border-stone-800 hover:border-stone-300 dark:hover:border-stone-600 bg-white dark:bg-stone-900/60 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 transition-all duration-200"
            style={`--stagger:${i * 50}ms`}
            data-project={project.slug}
            role="button"
            tabindex="0"
            onclick={`openModal('${project.slug}')`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();openModal('${project.slug}')}`}
          >
            {/* Image */}
            <div class="w-32 flex-shrink-0 overflow-hidden bg-stone-100 dark:bg-stone-800">
              {project.images.length > 0 ? (
                <img
                  src={`/${project.images[0]}`}
                  alt={locale.title}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  width="128"
                  height="160"
                  class={`w-full h-full object-cover ${objPos}`}
                />
              ) : (
                <div class="w-full h-full min-h-[120px]" style={`background: ${project.gradient}`}></div>
              )}
            </div>

            {/* Content */}
            <div class="flex-1 min-w-0 p-4 flex flex-col justify-between">
              <div>
                <h3 class="font-medium text-stone-900 dark:text-stone-100 text-sm tracking-tight group-hover:text-accent transition-colors duration-200" data-i18n={`projects.${project.slug}.title`}>{locale.title}</h3>
                <p class="text-xs text-stone-400 dark:text-stone-500 mt-0.5 mb-2">{locale.subtitle}</p>
                <p class="text-xs text-stone-500 dark:text-stone-400 leading-relaxed hidden sm:block">{desc}</p>
              </div>
              <div class="flex gap-1.5 flex-wrap mt-3">
                {project.tags.slice(0, 4).map(tag => (
                  <span class="text-[10px] px-1.5 py-0.5 border border-stone-200 dark:border-stone-700 rounded-full text-stone-400 dark:text-stone-500">{tag}</span>
                ))}
                {project.tags.length > 4 && (
                  <span class="text-[10px] text-stone-300 dark:text-stone-600">+{project.tags.length - 4}</span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

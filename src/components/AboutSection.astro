---
import { t } from '../i18n/utils';

const skills = ['skill1', 'skill2', 'skill3', 'skill4', 'skill5', 'skill6', 'skill7', 'skill8'];
---

<section id="about" class="py-12 px-6 border-t border-stone-100">
  <div class="max-w-xl mx-auto reveal">
    <p class="text-xs text-accent font-medium tracking-[0.2em] uppercase mb-2" data-i18n="about.label">{t('about.label')}</p>
    <h2 class="font-light text-stone-900 text-2xl mb-5 tracking-tight" data-i18n="about.title">{t('about.title')}</h2>
    <p class="text-stone-500 text-sm leading-[1.8] mb-3" data-i18n="about.bio1" data-i18n-html="true" set:html={t('about.bio1')} />
    <p class="text-stone-500 text-sm leading-[1.8] mb-5" data-i18n="about.bio2">{t('about.bio2')}</p>
    <div class="flex flex-wrap gap-1.5">
      {skills.map(s => (
        <span class="text-[11px] px-2.5 py-1 bg-stone-50 border border-stone-200 rounded-full text-stone-500 font-medium hover:bg-accent hover:text-white hover:border-accent transition-all duration-200 cursor-default" data-i18n={`about.${s}`}>{t(`about.${s}`)}</span>
      ))}
    </div>
  </div>
</section>

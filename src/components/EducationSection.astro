---
import { t } from '../i18n/utils';
---

<section class="py-8 px-6 border-t border-stone-100">
  <div class="max-w-2xl mx-auto">
    <h3 class="font-medium text-stone-900 text-sm mb-4 tracking-tight reveal" data-i18n="journey.education">{t('journey.education')}</h3>
    <div class="space-y-2 reveal">
      <div class="flex items-baseline justify-between">
        <div>
          <span class="text-stone-900 text-sm font-medium" data-i18n="journey.edu1.school">{t('journey.edu1.school')}</span>
          <span class="text-stone-400 text-sm"> — </span>
          <span class="text-stone-500 text-sm" data-i18n="journey.edu1.degree">{t('journey.edu1.degree')}</span>
        </div>
      </div>
      <div class="flex items-baseline justify-between">
        <div>
          <span class="text-stone-900 text-sm font-medium" data-i18n="journey.edu2.school">{t('journey.edu2.school')}</span>
          <span class="text-stone-400 text-sm"> — </span>
          <span class="text-stone-500 text-sm" data-i18n="journey.edu2.degree">{t('journey.edu2.degree')}</span>
        </div>
      </div>
    </div>

    <div class="mt-5 reveal">
      <h3 class="font-medium text-stone-900 text-sm mb-2 tracking-tight" data-i18n="journey.certifications">{t('journey.certifications')}</h3>
      <div class="flex flex-wrap gap-1.5">
        <span class="text-[11px] px-2 py-0.5 border border-stone-200 rounded-full text-stone-400" data-i18n="journey.cert1">{t('journey.cert1')}</span>
        <span class="text-[11px] px-2 py-0.5 border border-stone-200 rounded-full text-stone-400" data-i18n="journey.cert2">{t('journey.cert2')}</span>
        <span class="text-[11px] px-2 py-0.5 border border-stone-200 rounded-full text-stone-400" data-i18n="journey.cert3">{t('journey.cert3')}</span>
      </div>
    </div>
  </div>
</section>

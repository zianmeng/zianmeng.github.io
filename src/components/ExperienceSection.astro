---
import { t } from '../i18n/utils';

const roles = [
  { id: 'role1', details: ['detail1', 'detail2'] },
  { id: 'role2', details: ['detail1', 'detail2'] },
  { id: 'role3', details: ['detail1'] },
  { id: 'role4', details: ['detail1'] },
];
---

<section id="journey" class="py-12 px-6 border-t border-stone-100 dark:border-stone-800">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-light text-stone-900 dark:text-stone-100 text-2xl mb-6 tracking-tight reveal" data-i18n="journey.title">{t('journey.title')}</h2>

    <div class="space-y-6 reveal">
      {roles.map(role => (
        <div class="timeline-item cursor-pointer group rounded-lg px-3 py-2 -mx-3 hover:bg-stone-50 dark:hover:bg-stone-900/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-stone-950 transition-colors duration-200" role="button" tabindex="0" onclick="toggleTimeline(this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleTimeline(this)}">
          <div class="flex items-baseline justify-between gap-3 mb-0.5">
            <h3 class="font-medium text-stone-900 dark:text-stone-100 text-base tracking-tight">
              <span data-i18n={`journey.${role.id}`}>{t(`journey.${role.id}`)}</span>
              <span class="text-stone-400 dark:text-stone-600 font-normal"> at </span>
              <span class="text-stone-600 dark:text-stone-400 font-normal" data-i18n={`journey.${role.id}.company`}>{t(`journey.${role.id}.company`)}</span>
            </h3>
          </div>
          <p class="text-xs text-stone-400 dark:text-stone-500 mb-1">
            <span data-i18n={`journey.${role.id}.date`}>{t(`journey.${role.id}.date`)}</span>
          </p>
          <div class="timeline-details">
            {role.details.map(d => (
              <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed mt-1.5" data-i18n={`journey.${role.id}.${d}`}><span class="text-stone-400 dark:text-stone-600 mr-1.5">—</span>{t(`journey.${role.id}.${d}`)}</p>
            ))}
          </div>
          <span class="expand-hint text-[11px] text-stone-300 dark:text-stone-600 group-hover:text-accent transition-colors duration-200" data-i18n="journey.expand">{t('journey.expand')}</span>
        </div>
      ))}
    </div>
  </div>
</section>

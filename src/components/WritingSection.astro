---
import { posts } from '../data/posts';

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<section id="writing" class="py-12 px-6 border-t border-stone-100">
  <div class="max-w-2xl mx-auto">
    <p class="text-xs text-accent font-medium tracking-[0.2em] uppercase mb-3 reveal">Writing</p>
    <h2 class="font-light text-stone-900 text-3xl mb-8 tracking-tight reveal">Recent Posts</h2>

    <div class="space-y-4 reveal">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="flex justify-between items-baseline gap-4 group no-underline py-1.5">
          <span class="text-stone-900 text-sm font-normal group-hover:text-accent transition-colors duration-200">{post.title}</span>
          <span class="text-xs text-stone-300 whitespace-nowrap">{formatDate(post.date)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Zian Meng — Product Designer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <meta name="description" content="Zian Meng — Product designer and photographer crafting thoughtful, user-centered digital experiences." />
  <meta property="og:title" content="Zian Meng — Product Designer" />
  <meta property="og:description" content="Product designer and builder based in New York, crafting thoughtful, user-centered digital experiences. Also a photographer." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://zianmeng.github.io" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Zian Meng — Product Designer" />
  <meta name="twitter:description" content="Product designer and builder based in New York." />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white dark:bg-stone-950 text-stone-600 dark:text-stone-400 font-sans font-light leading-relaxed overflow-x-hidden transition-colors duration-200">
  <slot />
</body>
</html>
